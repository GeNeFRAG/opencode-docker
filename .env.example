# ═══════════════════════════════════════════════════════════════════
# OpenCode Web Docker - Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── OpenCode Settings ─────────────────────────────────────────────
OPENCODE_MODEL=rbigenai/claude-opus-4-6

# ─── RBI GenAI Provider ───────────────────────────────────────────
RBIGENAI_BASE_URL=https://genai-sbox.rbi.tech
RBIGENAI_API_KEY=your-rbi-genai-api-key-here

# ─── OpenRouter Provider ─────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── GitHub MCP (RBI) ────────────────────────────────────────────
GITHUB_RBI_TOKEN=your-github-rbi-token-here

# ─── GitHub MCP (Personal) ───────────────────────────────────────
GITHUB_PERSONAL_TOKEN=your-github-personal-token-here

# ─── Atlassian / Confluence ──────────────────────────────────────
CONFLUENCE_URL=https://wiki.rbinternational.com/confluence
CONFLUENCE_USERNAME=your-email@rbinternational.com
CONFLUENCE_TOKEN=your-confluence-token-here

# ─── Atlassian / Jira ───────────────────────────────────────────
JIRA_URL=https://jira.rbinternational.com/jira
JIRA_USERNAME=your-email@rbinternational.com
JIRA_TOKEN=your-jira-token-here

# ─── Grafana ─────────────────────────────────────────────────────
GRAFANA_URL=https://rbinternational.grafana.net/
GRAFANA_API_KEY=your-grafana-api-key-here

# ─── Repos Parent Path ───────────────────────────────────────────
# Parent directory containing all your git repos
REPOS_PATH=~/LocalCode/Code
