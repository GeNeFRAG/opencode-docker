{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "rbigenai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "RBI GenAI",
      "options": {
        "baseURL": "${RBIGENAI_BASE_URL}",
        "apiKey": "${RBIGENAI_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": { "label": "Claude Sonnet 4.6" },
        "claude-sonnet-4-5": { "label": "Claude Sonnet 4.5" },
        "claude-opus-4-6": { "label": "Claude Opus 4.6" },
        "claude-opus-4-5": { "label": "Claude Opus 4.5" },
        "claude-haiku-4-5": { "label": "Claude Haiku 4.5" },
        "gpt-5": { "label": "GPT-5" },
        "gpt-5-pro": { "label": "GPT-5 Pro" },
        "gpt-5-mini": { "label": "GPT-5 Mini" },
        "gpt-5-nano": { "label": "GPT-5 Nano" },
        "gpt-5-codex": { "label": "GPT-5 Codex" },
        "gpt-4.1": { "label": "GPT-4.1" },
        "gpt-4.1-mini": { "label": "GPT-4.1 Mini" },
        "gpt-4.1-nano": { "label": "GPT-4.1 Nano" },
        "gpt-4o": { "label": "GPT-4o" },
        "gpt-4o-mini": { "label": "GPT-4o Mini" },
        "o3": { "label": "OpenAI o3" },
        "o3-mini": { "label": "OpenAI o3 Mini" },
        "o3-deep-research": { "label": "OpenAI o3 Deep Research" },
        "o4-mini": { "label": "OpenAI o4 Mini" },
        "Mistral-Large-3": { "label": "Mistral Large 3" },
        "llama3-2-3b-instruct-v1": { "label": "Llama 3.2 3B Instruct" },
        "model-router": { "label": "Model Router (Auto)" }
      }
    },
    "openrouter": {
      "npm": "@openrouter/ai-sdk-provider",
      "name": "OpenRouter",
      "options": {
        "apiKey": "${OPENROUTER_API_KEY}"
      },
      "models": {
        "meta-llama/llama-4-scout": { "label": "Llama 4 Scout (10M context)" },
        "meta-llama/llama-4-maverick": { "label": "Llama 4 Maverick (Vision)" },
        "deepseek/deepseek-r1": { "label": "DeepSeek R1 (Reasoning)" },
        "deepseek/deepseek-v3": { "label": "DeepSeek V3" }
      }
    }
  },
  "model": "${OPENCODE_MODEL}",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker", "run", "-i", "--rm",
        "-v", "/Users/gerhard.froehlich/tls-ca-bundle_3.pem:/certs/zscaler.pem:ro",
        "-e", "REQUESTS_CA_BUNDLE=/certs/zscaler.pem",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e", "GITHUB_HOST",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_RBI_TOKEN}",
        "GITHUB_HOST": "https://code.rbi.tech"
      }
    },
    "github_personal": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker", "run", "-i", "--rm",
        "-v", "/Users/gerhard.froehlich/tls-ca-bundle_3.pem:/certs/zscaler.pem:ro",
        "-e", "REQUESTS_CA_BUNDLE=/certs/zscaler.pem",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e", "GITHUB_HOST",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_TOKEN}",
        "GITHUB_HOST": "https://github.com/"
      }
    },
    "mcp-atlassian": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker", "run", "--rm", "-i",
        "-e", "CONFLUENCE_URL",
        "-e", "CONFLUENCE_USERNAME",
        "-e", "CONFLUENCE_PERSONAL_TOKEN",
        "-e", "CONFLUENCE_SSL_VERIFY",
        "-e", "JIRA_URL",
        "-e", "JIRA_USERNAME",
        "-e", "JIRA_PERSONAL_TOKEN",
        "-e", "JIRA_SSL_VERIFY",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "environment": {
        "CONFLUENCE_URL": "${CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "${CONFLUENCE_USERNAME}",
        "CONFLUENCE_PERSONAL_TOKEN": "${CONFLUENCE_TOKEN}",
        "CONFLUENCE_SSL_VERIFY": "false",
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_USERNAME": "${JIRA_USERNAME}",
        "JIRA_SSL_VERIFY": "false",
        "JIRA_PERSONAL_TOKEN": "${JIRA_TOKEN}"
      }
    },
    "grafana": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker", "run", "--rm", "-i",
        "-v", "/Users/gerhard.froehlich/tls-ca-bundle_3.pem:/certs/zscaler.pem:ro",
        "-e", "GRAFANA_URL",
        "-e", "GRAFANA_API_KEY",
        "mcp/grafana",
        "-t", "stdio",
        "--tls-ca-file", "/certs/zscaler.pem"
      ],
      "environment": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_API_KEY": "${GRAFANA_API_KEY}"
      }
    },
    "memory": {
      "type": "local",
      "command": [
        "npx", "-y", "@modelcontextprotocol/server-memory@latest"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "/root/.config/opencode/memory.json"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx", "-y", "@upstash/context7-mcp@latest"
      ]
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx", "-y", "@modelcontextprotocol/server-sequential-thinking@latest"
      ]
    },
    "grep_app": {
      "type": "local",
      "command": [
        "npx", "-y", "@anthropics/grep-app-mcp@latest"
      ]
    },
    "time": {
      "type": "local",
      "command": [
        "npx", "-y", "mcp-time-server@latest"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx", "-y", "@playwright/mcp@latest"
      ]
    },
    "git": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx", "-y", "@cyanheads/git-mcp-server@latest"
      ]
    }
  }
}
