{
  "$schema": "https://opencode.ai/config.json",
  "theme": "${OPENCODE_TUI_THEME}",
  "provider": {
    "llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLM Gateway",
      "options": {
        "baseURL": "${LLM_EFFECTIVE_URL}",
        "apiKey": "${LLM_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": { "label": "Claude Sonnet 4.6" },
        "claude-sonnet-4-5": { "label": "Claude Sonnet 4.5" },
        "claude-opus-4-6": { "label": "Claude Opus 4.6" },
        "claude-opus-4-5": { "label": "Claude Opus 4.5" },
        "claude-haiku-4-5": { "label": "Claude Haiku 4.5" },
        "gpt-5": { "label": "GPT-5" },
        "gpt-5-pro": { "label": "GPT-5 Pro" },
        "gpt-5-mini": { "label": "GPT-5 Mini" },
        "gpt-5-nano": { "label": "GPT-5 Nano" },
        "gpt-5-codex": { "label": "GPT-5 Codex" },
        "gpt-4.1": { "label": "GPT-4.1" },
        "gpt-4.1-mini": { "label": "GPT-4.1 Mini" },
        "gpt-4.1-nano": { "label": "GPT-4.1 Nano" },
        "gpt-4o": { "label": "GPT-4o" },
        "gpt-4o-mini": { "label": "GPT-4o Mini" },
        "o3": { "label": "OpenAI o3" },
        "o3-mini": { "label": "OpenAI o3 Mini" },
        "o3-deep-research": { "label": "OpenAI o3 Deep Research" },
        "o4-mini": { "label": "OpenAI o4 Mini" },
        "Mistral-Large-3": { "label": "Mistral Large 3" },
        "llama3-2-3b-instruct-v1": { "label": "Llama 3.2 3B Instruct" },
        "model-router": { "label": "Model Router (Auto)" }
      }
    }
  },
  "model": "${OPENCODE_MODEL}",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "allow",
    "codesearch": "allow",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "git remote *": "allow",
      "git stash list *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git checkout *": "allow",
      "git switch *": "allow",
      "git fetch *": "allow",
      "git pull *": "allow",
      "git merge *": "allow",
      "git rebase *": "ask",
      "git push *": "ask",
      "git push --force *": "deny",
      "git push --force-with-lease *": "ask",
      "git reset --hard *": "deny",
      "git clean *": "deny",
      "npm *": "allow",
      "npx *": "allow",
      "node *": "allow",
      "bun *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "env": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "touch *": "allow",
      "chmod *": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "docker *": "ask",
      "kill *": "deny",
      "killall *": "deny",
      "pkill *": "deny",
      "sudo *": "deny",
      "sh -c *": "ask",
      "bash -c *": "ask"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "command": {
    "advanced-elicitation": {
      "description": "Push the LLM to reconsider, refine, and improve its recent output. Use when user asks for deeper critique or mentions a known deeper critique method, e.g. socratic, first principles, pre-mortem, red team.",
